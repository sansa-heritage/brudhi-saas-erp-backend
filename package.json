{
  "name": "gasflow-erp-saas",
  "version": "1.0.0",
  "description": "Multi-tenant Gas Agency Management System with Separate Databases",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "setup:main-db": "node src/database/setup-main-db.js",
